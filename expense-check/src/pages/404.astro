---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="ページが見つかりません">
  <section class="container page">
    <p class="num page__code">404</p>
    <h1 class="page__title">ページが見つかりません</h1>
    <p class="page__text">お探しのページは存在しないか、移動した可能性があります。</p>
    <a href={base} class="button">シミュレーターへ戻る</a>
  </section>
</Layout>

<style>
  .page {
    padding: var(--sp-6) var(--sp-4);
    text-align: center;
  }
  .page__code {
    font-size: clamp(3rem, 2rem + 6vw, 6rem);
    font-weight: 700;
    color: var(--color-primary-text);
    line-height: 1;
  }
  .page__title {
    margin: var(--sp-3) 0;
  }
  .page__text {
    color: var(--color-muted);
    margin-bottom: var(--sp-4);
  }
</style>
